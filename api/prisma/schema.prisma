generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Audience {
  id        String    @id @default(cuid())
  name      String
  contacts  Contact[]
  createdAt DateTime  @default(now())
}

model Contact {
  id         String   @id @default(cuid())
  phone      String
  audienceId String
  audience   Audience @relation(fields: [audienceId], references: [id], onDelete: Cascade)
}